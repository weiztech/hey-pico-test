# Docker Compose environment variables for Django
COMPOSE_PROJECT_NAME=test-heypico

# Django app settings
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=django-insecure-change-me
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Server binding inside container
DJANGO_HOST=0.0.0.0
DJANGO_PORT=8000

# Google Maps
GOOGLE_MAPS_API_KEY="your google key here"

# Signed URL RATE LIMIT
SIGNED_URL_RATE_LIMIT=20
SIGNED_URL_MAX_AGE=3600  # seconds (1 hour)
